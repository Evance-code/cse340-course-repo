<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% if (messages.success) { %>
            <% messages.success.forEach(msg=> { %>
                <p style="color:green">
                    <%= msg %>
                </p>
                <% }) %>
                    <% } %>
                        <% if (messages.error) { %>
                            <% messages.error.forEach(msg=> { %>
                                <p style="color:red">
                                    <%= msg %>
                                </p>
                                <% }) %>
                                    <% } %>

                                        <h2>
                                            <%= project.title %>
                                        </h2>
                                        <p>
                                            <%= project.description %>
                                        </p>
                                        <p><strong>Date:</strong>
                                            <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric' ,
                                                month: 'long' , day: 'numeric' }) %>
                                        </p>
                                        <p><strong>Location:</strong>
                                            <%= project.location %>
                                        </p>
                                        <p><strong>Organization:</strong>
                                            <a href="/organization/<%= project.organization_id %>">
                                                <%= project.organization_name %>
                                            </a>
                                        </p>

                                        <% if (categories && categories.length> 0) { %>
                                            <p><strong>Categories:</strong></p>
                                            <ul>
                                                <% categories.forEach(category=> { %>
                                                    <li><a href="/category/<%= category.category_id %>">
                                                            <%= category.name %>
                                                        </a></li>
                                                    <% }) %>
                                            </ul>
                                            <% } %>

                                                <% if (isLoggedIn) { %>
                                                    <% if (isVolunteering) { %>
                                                        <p>✅ You are volunteering for this project!</p>
                                                        <form method="POST"
                                                            action="/project/<%= project.project_id %>/unvolunteer">
                                                            <button type="submit">Remove myself as volunteer</button>
                                                        </form>
                                                        <% } else { %>
                                                            <form method="POST"
                                                                action="/project/<%= project.project_id %>/volunteer">
                                                                <button type="submit">Volunteer for this
                                                                    project</button>
                                                            </form>
                                                            <% } %>
                                                                <% } %>

                                                                    <% if (user && user.role_name==='admin' ) { %>
                                                                        <p>
                                                                            <a
                                                                                href="/edit-project/<%= project.project_id %>">Edit
                                                                                Project</a> |
                                                                            <a
                                                                                href="/project/<%= project.project_id %>/assign-categories">Edit
                                                                                Categories</a>
                                                                        </p>
                                                                        <% } %>
    </main>

    <%- include('partials/footer') %>