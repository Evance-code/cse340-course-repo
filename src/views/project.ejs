<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= project.title %>
        </h2>
        <p>
            <%= project.description %>
        </p>
        <p><strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' })
                %>
        </p>
        <p><strong>Location:</strong>
            <%= project.location %>
        </p>
        <p><strong>Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <% if (categories && categories.length> 0) { %>
            <p><strong>Categories:</strong></p>
            <ul class="category-tags">
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>" class="category-tag">
                            <%= category.name %>
                        </a>
                    </li>
                    <% }) %>
            </ul>
            <% } %>

                <p>
                    <a href="/edit-project/<%= project.project_id %>">Edit Project</a> |
                    <a href="/project/<%= project.project_id %>/assign-categories">Edit Categories</a>
                </p>
    </main>

    <%- include('partials/footer') %>