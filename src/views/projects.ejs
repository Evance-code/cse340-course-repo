<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <strong>
                        <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                            day: 'numeric' }) %>:
                            <%= project.title %>
                    </strong>
                    (<%= project.organization_name %>)
                        <p>
                            <%= project.description %>
                        </p>
                        <p>Location: <%= project.location %>
                        </p>
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include('partials/footer') %>