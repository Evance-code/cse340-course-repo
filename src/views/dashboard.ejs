<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% if (messages.success) { %>
            <% messages.success.forEach(msg=> { %>
                <p style="color:green">
                    <%= msg %>
                </p>
                <% }) %>
                    <% } %>

                        <p>Welcome, <%= name %>!</p>
                        <p>Email: <%= email %>
                        </p>

                        <p><a href="/volunteering">My Volunteering Projects</a></p>

                        <% if (user && user.role_name==='admin' ) { %>
                            <p><a href="/users">View All Users</a></p>
                            <% } %>
    </main>

    <%- include('partials/footer') %>