<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are our service project categories:</p>
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                    | <a href="/edit-category/<%= category.category_id %>">Edit</a>
                </li>
                <% }) %>
        </ul>

        <p><a href="/new-category">Add a new category</a></p>
    </main>

    <%- include('partials/footer') %>