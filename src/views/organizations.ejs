<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <ul>
            <% organizations.forEach(org=> { %>
                <li>
                    <a href="/organization/<%= org.organization_id %>">
                        <%= org.name %>
                    </a>
                </li>
                <% }) %>
        </ul>

        <p><a href="/new-organization">Add a new organization</a></p>
    </main>

    <%- include('partials/footer') %>