<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% if (messages.error) { %>
            <% messages.error.forEach(msg=> { %>
                <p style="color:red">
                    <%= msg %>
                </p>
                <% }) %>
                    <% } %>

                        <form method="POST" action="/edit-organization/<%= organizationDetails.organization_id %>">
                            <div>
                                <label for="name">Name:</label>
                                <input type="text" id="name" name="name" value="<%= organizationDetails.name %>"
                                    required>
                            </div>
                            <div>
                                <label for="description">Description:</label>
                                <textarea id="description" name="description"
                                    required><%= organizationDetails.description %></textarea>
                            </div>
                            <div>
                                <label for="contact_email">Contact Email:</label>
                                <input type="email" id="contact_email" name="contact_email"
                                    value="<%= organizationDetails.contact_email %>" required>
                            </div>
                            <div>
                                <label for="logo_filename">Logo Filename:</label>
                                <input type="text" id="logo_filename" name="logo_filename"
                                    value="<%= organizationDetails.logo_filename %>" required>
                            </div>
                            <button type="submit">Update Organization</button>
                        </form>
                        <a href="/organization/<%= organizationDetails.organization_id %>">Cancel</a>
    </main>

    <%- include('partials/footer') %>