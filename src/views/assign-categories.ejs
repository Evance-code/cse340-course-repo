<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>
            <%= project.title %>
        </h2>

        <form action="/project/<%= project.project_id %>/assign-categories" method="POST">
            <div class="form-group">
                <% categories.forEach(category=> { %>
                    <div>
                        <input type="checkbox" id="category-<%= category.category_id %>" name="categoryIds"
                            value="<%= category.category_id %>" <%=assignedCategories.some(ac=> ac.category_id ===
                        category.category_id) ? 'checked' : '' %>
                        />
                        <label for="category-<%= category.category_id %>">
                            <%= category.name %>
                        </label>
                    </div>
                    <% }) %>
            </div>

            <button type="submit">Save Categories</button>
        </form>

        <p><a href="/project/<%= project.project_id %>">Back to Project</a></p>
    </main>

    <%- include('partials/footer') %>